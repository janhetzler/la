# Library: keep the category folders, ignore their contents and processed dumps
data/library/ibm/*
data/library/research/*
data/library/personal/*
data/library/admin/*
data/library/inbox/*
data/library/_indexed/
data/library/_errors/
data/library/test-docs/
!data/library/*/.gitkeep

# Models: ignore weights (they're downloaded by the installer) but keep folder
models/whisper/*.bin
models/whisper.cpp/

# Logs
logs/*
!logs/.gitkeep

# Vault (personal notes — never commit)
vault/*/
!vault/*/.gitkeep

